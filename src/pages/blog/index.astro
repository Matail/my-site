---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout>
	<header class="site-header">
		<a href="/" class="logo">
			<span class="logo-mark"></span>
			<span>my-site</span>
		</a>
		<nav>
			<a href="/games">게임</a>
			<a href="/blog" class="active">블로그</a>
			<a href="/about">소개</a>
			<a href="/games" class="cta-pill">PLAY →</a>
		</nav>
	</header>

	<main>
		<section class="intro">
			<p class="kicker">★ BLOG</p>
			<h1>만든 것,<br><span class="accent">배운 것.</span></h1>
			<p class="lead">게임 만들면서 마주친 문제와 그걸 푸는 과정을 기록해요.</p>
		</section>

		<section class="posts">
			{posts.map((post) => (
				<a href={`/blog/${post.id}/`} class="post-card">
					<div class="post-meta">
						<time>{post.data.pubDate.toLocaleDateString('ko-KR')}</time>
						{post.data.tags && (
							<div class="tags">
								{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
							</div>
						)}
					</div>
					<h2>{post.data.title}</h2>
					<p>{post.data.description}</p>
				</a>
			))}
		</section>
	</main>

	<footer class="site-footer">
		<p>© 2026 my-site · <a href="mailto:hello@example.com">contact</a></p>
	</footer>
</Layout>

<style>
	/* 헤더 */
	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 2rem;
		max-width: 1100px;
		margin: 0 auto;
	}

	.logo {
		display: flex; align-items: center; gap: 10px;
		font-weight: 800; font-size: 1.1rem; color: var(--text);
	}
	.logo:hover { text-decoration: none; }
	.logo-mark {
		display: inline-block; width: 24px; height: 24px;
		background: var(--lime); border-radius: 6px;
	}
	.site-header nav { display: flex; gap: 1.5rem; align-items: center; }
	.site-header nav a {
		color: var(--text-muted); font-weight: 500; font-size: 0.95rem;
	}
	.site-header nav a:hover { color: var(--text); text-decoration: none; }
	.site-header nav a.active { color: var(--text); }
	.cta-pill {
		background: var(--lime); color: var(--bg) !important;
		padding: 8px 18px; border-radius: 999px;
		font-weight: 700 !important; font-size: 0.85rem !important;
		transition: transform 0.15s;
	}
	.cta-pill:hover { transform: translateY(-2px); text-decoration: none; }

	/* 본문 */
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem;
	}

	.intro {
		padding: 2rem 0 3rem;
	}

	.kicker {
		color: var(--lime); font-size: 0.85rem; font-weight: 700;
		letter-spacing: 0.15em; margin: 0 0 1rem;
	}

	.intro h1 {
		font-size: 4rem; font-weight: 900; line-height: 0.95;
		letter-spacing: -0.04em; margin: 0 0 1rem;
	}

	.accent { color: var(--lime); }

	.lead {
		font-size: 1.1rem; color: var(--text-muted);
		max-width: 540px; margin: 0;
	}

	/* 글 카드 리스트 */
	.posts {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-card {
		display: block;
		padding: 1.5rem;
		background: var(--surface);
		border-radius: 16px;
		color: var(--text);
		transition: transform 0.15s, background 0.15s;
	}

	.post-card:hover {
		text-decoration: none;
		transform: translateY(-2px);
		background: var(--surface-light);
	}

	.post-meta {
		display: flex;
		gap: 1rem;
		align-items: center;
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
	}

	.tag {
		color: var(--lime);
	}

	.post-card h2 {
		font-size: 1.4rem;
		margin: 0 0 0.5rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.post-card p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	/* 푸터 */
	.site-footer {
		max-width: 1100px; margin: 4rem auto 0; padding: 2rem;
		border-top: 1px solid var(--border);
		color: var(--text-muted); font-size: 0.9rem; text-align: center;
	}

	@media (max-width: 640px) {
		.site-header { padding: 1rem; flex-wrap: wrap; gap: 1rem; }
		.site-header nav { gap: 1rem; font-size: 0.85rem; }
		main { padding: 1rem; }
		.intro h1 { font-size: 2.75rem; }
	}
</style>
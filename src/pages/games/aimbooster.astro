---
// Aimbooster 게임 페이지
// 스타일과 스크립트는 public/games/aimbooster/ 에서 가져옴
---

<!DOCTYPE html>
<html lang="ko">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Aimbooster — my-site</title>
	<link rel="stylesheet" href="/games/aimbooster/style.css">
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link rel="stylesheet" as="style"
		href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css">
</head>
<body>
	<a href="/games/" class="back-link">← 게임 목록</a>

	<header class="game-header">
		<div class="stats">
			<div class="stat">
				<span class="stat-label">TIME</span>
				<span class="stat-value" id="time">0.0</span>
			</div>
			<div class="stat">
				<span class="stat-label">SCORE</span>
				<span class="stat-value" id="score">0</span>
			</div>
			<div class="stat">
				<span class="stat-label">MISS</span>
				<span class="stat-value" id="miss">0 / 3</span>
			</div>
		</div>
	</header>

	<div class="arena" id="arena">
		<div class="overlay" id="start-screen">
			<h1>AIMBOOSTER</h1>
			<p>다트 보드를 빠르게 클릭하세요.<br>3번 놓치면 게임 끝.</p>
			<button class="start-btn" id="start-btn">START</button>
		</div>

		<div class="overlay hidden" id="end-screen">
			<h1>GAME OVER</h1>
			<div class="final-stats">
				<p>버틴 시간: <span id="final-time">0.0</span>초</p>
				<p>맞춘 과녁: <span id="final-score">0</span>개</p>
			</div>
			<button class="start-btn" id="restart-btn">RETRY</button>
		</div>
	</div>

	<script is:inline src="/games/aimbooster/script.js"></script>
</body>
</html>